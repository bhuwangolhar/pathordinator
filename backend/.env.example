# Server Configuration
PORT=8080
NODE_ENV=development

# Database Configuration
# For local development:
DB_NAME=pathordinator
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=127.0.0.1
DB_PORT=5432

# For production, use DATABASE_URL instead:
# DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# JWT Secret (REQUIRED - use a strong random string, at least 64 characters)
JWT_SECRET=your_jwt_secret_here_minimum_64_characters_long_use_random_generator

# CORS Configuration (for production)
# CORS_ORIGIN=https://your-frontend-domain.com
